# ==============================================================================
# CORE IMMICH CONNECTION SETTINGS
# ==============================================================================
IMMICH_API_KEY="********************************"
IMMICH_URL="http://immich-server:2283"

# Optional: The browser-accessible URL of your Immich instance (e.g., https://photos.your.tld).
# Used to generate clickable photo links in the logs for easy image lookup.
# Defaults to IMMICH_URL (fine if you browse via that exact address; change if IMMICH_URL is an internal Docker address).
IMMICH_PUBLIC_URL="https://immich.0x123.dev"

# Logging verbosity: DEBUG | INFO | WARNING | ERROR (default INFO).
LOG_LEVEL="INFO"


# ==============================================================================
# HARDWARE & CANVAS INFRASTRUCTURE
# ==============================================================================
# landscape (default) | portrait
# Structure of the underlying canvas.
# - landscape: 800x480 canvas, places dual photos side-by-side.
# - portrait: 480x800 canvas, places dual photos stacked top-to-bottom.
IMMICH_DEVICE_ORIENTATION="landscape"

# 0 | 90 | 180 | 270 (default 0)
# Final hardware rotation angle applied to the canvas before packing into binary format.
FRAME_ROTATE="0"


# ==============================================================================
# CONTENT SELECTION & FILTERS
# ==============================================================================
# Option A: A single curated album.
# Note: People/date filters are ignored in album mode, except IMMICH_EXCLUDE_PEOPLE which still applies.
IMMICH_ALBUM_ID=

# Option B: Leave ALBUM_ID blank to utilize whole-library search mode.
# Comma-separated Immich Person UUIDs (found in your browser's URL bar when clicking a person in Immich).
IMMICH_INCLUDE_PEOPLE=""

# Comma-separated Immich Person UUIDs. Any asset containing these people will be dropped locally.
IMMICH_EXCLUDE_PEOPLE=""

# true  = Asset must contain ALL listed people (AND logic)
# false = Asset can contain any of the listed people (OR logic - picks one at random per search)
IMMICH_REQUIRE_ALL_PEOPLE="false"

# Date ranges evaluated against EXIF creation dates.
# Relative dates like "today", "yesterday", or "30d" (or "30 days ago") are dynamically parsed.
IMMICH_DATE_AFTER="2021-01-01"
IMMICH_DATE_BEFORE="today"


# ==============================================================================
# LAYOUT COMPOSITION & QUALITY RANKING PIPELINE
# ==============================================================================
# Max number of image candidates pulled per API search batch (1 to 1000).
IMMICH_SEARCH_BATCH="1000"

# any | landscape | portrait | square
# Strict layout filter applied to asset discovery.
# Default is 'any' to allow dynamic duo handling. Setting this to 'landscape' or 'portrait' will bypass duo layouts.
IMMICH_ASSET_ORIENTATION="any"

# 0.0 to 1.0 (default 0.5).
# Probability of using a "Duo" split-photo layout of opposing orientations instead of a single image.
# 0.0 disables duo layouts entirely; 1.0 forces a duo layout every time.
IMMICH_DUO_PROBABILITY="0.5"

# center | smart
# - center: Standard centered crop.
# - smart: Uses Immich's native face-bounding boxes to auto-center on family/friends. Falls back to center on error.
IMMICH_CROP="smart"
IMMICH_MIN_CROP_RETENTION="0.5"

# true (default) | false. If false, candidate layouts are picked completely at random.
IMMICH_QUALITY_ENABLED="true"

# Number of unique layout variations generated and scored per refresh (default 5).
# The highest scoring configuration (based on pyiqa NIMA/BRISQUE models and Laplacian sharpness) is served.
IMMICH_RANKING_BATCH="5"


# ==============================================================================
# FRAME CACHING
# ==============================================================================
# true | false (default false).
# When true, /frame.bin, /frame.png, and /frame.jpg all serve the same cached frame
# until POST /refresh is called (e.g. via cron). When false, every request generates
# a new frame on the fly (original behavior).
IMMICH_CACHE_ENABLED="true"


# ==============================================================================
# OSD TEXT LABELS (ON-SCREEN DISPLAY)
# ==============================================================================
# true (default) | false. Superimposes recognized person names and the creation year onto the panel.
IMMICH_SHOW_NAMES="true"

# true (default) | false. Splits person names on whitespace to only show first names.
IMMICH_FIRST_NAME_ONLY="true"

# Font file name (excluding the .ttf extension). Assumed to reside under /usr/share/fonts/truetype/dejavu/.
# e.g., "DejaVuSans-Bold", "DejaVuSansMono", "DejaVuSerif". Falls back to system default if missing.
IMMICH_LABEL_FONT="DejaVuSansMono"

# Font size in pixels (default 12).
IMMICH_LABEL_FONT_SIZE="12"

# String delimiter placed between names. Whitespace is preserved (e.g., " • " -> "Henry • Maya").
IMMICH_LABEL_DELIMITER=" • "

# Horizontal text padding (in pixels) inside the white label box (default 8).
IMMICH_LABEL_PADDING_X="8"

# Vertical text padding (in pixels) inside the white label box (default 4).
IMMICH_LABEL_PADDING_Y="4"

# top-left | top-middle | top-right | bottom-left | bottom-middle | bottom-right (default)
# Position of the label box. In Duo layouts, positioning is relative to the photo SLOT, not the global canvas.
IMMICH_LABEL_CORNER="bottom-right"
